rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Grant access to any authenticated user for each specific collection
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/logos/{logoId} {
      allow read, write: if request.auth != null;
    }
    match /volunteers/{volunteerId} {
      allow read, write: if request.auth != null;
    }
    match /roles_admin/{userId} {
      allow read, write: if request.auth != null;
    }
    match /sold_item_receipts/{receiptId} {
      allow read, write: if request.auth != null;
    }
    match /overtime/{overtimeId} {
      allow read, write: if request.auth != null;
    }
    match /bonuses/{bonusId} {
      allow read, write: if request.auth != null;
    }
    match /cash_withdrawals/{withdrawalId} {
      allow read, write: if request.auth != null;
    }
    match /employees/{employeeId} {
      allow read, write: if request.auth != null;
    }
     match /expenses/{expenseId} {
      allow read, write: if request.auth != null;
    }
    match /excel_files/{fileId} {
      allow read, write: if request.auth != null;
    }
    match /excel_files/{fileId}/items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /storage_locations/{locationId} {
      allow read, write: if request.auth != null;
    }
    match /items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /transfers/{transferId} {
      allow read, write: if request.auth != null;
    }
  }
}
