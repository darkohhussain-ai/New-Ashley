/**
 * Core Philosophy: This ruleset implements a hybrid security model. It combines strict
 * user-ownership for personal data with a role-based access control system for
 * administrative functions. A user has full control over their own data tree, while
 * designated administrators have privileged access to manage global resources and
 * oversee user data.
 *
 * Data Structure:
 * - /users/{userId}/*: All data directly related to a specific user (profile, settings, logos)
 *   is nested under their unique user ID. This enables simple and performant path-based
 *   security rules.
 * - /volunteers/*: A top-level collection for application-wide data (volunteers), which is
 *   managed exclusively by administrators.
 * - /roles_admin/{userId}: A special collection where the existence of a document grants
 *   a user administrative privileges across the application.
 *
 * Key Security Decisions:
 * - Admin Role Management: The `/roles_admin` collection is locked down from all
 *   client-side writes. This prevents users from promoting themselves to admin status.
 *   Admin roles must be assigned out-of-band by a trusted server process or manually
 *   in the Firebase Console.
 * - Admin Privilege Source: Administrative status is determined exclusively by checking for a
 *   document in `/roles_admin/{uid}`. The `isAdmin` flag on a user's profile document
 *   is ignored for authorization decisions to prevent users from modifying their own roles.
 * - No User Enumeration: Listing documents in the top-level `/users` collection is
 *   disallowed to protect user privacy and prevent data scraping.
 * - Denormalization for Authorization: This ruleset avoids complex `get()` calls where
 *   possible by relying on path-based ownership (e.g., `/users/{userId}`). For global
 *   roles, a single, efficient `exists()` call is used to check for admin status.
 * - Structural Segregation: User-specific data (`/users`) is structurally separate from
 *   admin-managed data (`/volunteers`), simplifying rules and securing list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user has administrative privileges.
     * Admin status is granted by the existence of a document in the `roles_admin` collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Checks if the user is either the owner of the resource or an admin.
     */
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    /**
     * Ensures a document exists before an update or delete operation.
     */
    function isExistingDoc() {
      return resource != null;
    }

    // ------------------------------------------------------------------------
    // User Data Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (get) An admin or the user themselves retrieving their own profile.
     * @allow (create) A new user creating their own profile document.
     * @deny (list) Any user attempting to list all user profiles.
     * @deny (update) A user trying to modify another user's profile.
     * @principle Restricts access to a user's own data tree, with admin oversight.
     */
    match /users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwnerOrAdmin(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
      allow delete: if isOwnerOrAdmin(userId) && isExistingDoc();

      /**
       * @description Manages user-specific application settings.
       * @path /users/{userId}/settings/{settingId}
       * @allow (create) A user creating a new settings document for their own account.
       * @allow (list) An admin listing all settings for a specific user.
       * @deny (get) A user attempting to read another user's settings.
       * @deny (delete) A user attempting to delete another user's settings.
       * @principle Enforces strict ownership of nested subcollection data.
       */
      match /settings/{settingId} {
        allow get: if isOwnerOrAdmin(userId);
        allow list: if isOwnerOrAdmin(userId);
        allow create: if isOwnerOrAdmin(userId) && request.resource.data.userId == userId;
        allow update: if isOwnerOrAdmin(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwnerOrAdmin(userId) && isExistingDoc();
      }

      /**
       * @description Manages user-specific logos.
       * @path /users/{userId}/logos/{logoId}
       * @allow (create) A user uploading a logo to their own account.
       * @allow (list) The user listing their own logos.
       * @deny (get) A user attempting to read another user's logo data.
       * @deny (update) A user trying to modify a logo belonging to someone else.
       * @principle Enforces strict ownership of nested subcollection data.
       */
      match /logos/{logoId} {
        allow get: if isOwnerOrAdmin(userId);
        allow list: if isOwnerOrAdmin(userId);
        allow create: if isOwnerOrAdmin(userId);
        allow update: if isOwnerOrAdmin(userId) && isExistingDoc();
        allow delete: if isOwnerOrAdmin(userId) && isExistingDoc();
      }
    }

    // ------------------------------------------------------------------------
    // Admin-Managed Data Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages volunteer information, accessible only by administrators.
     * @path /volunteers/{volunteerId}
     * @allow (create) An admin creating a new volunteer record.
     * @allow (list) An admin listing all volunteers.
     * @deny (get) A non-admin user trying to read a volunteer's data.
     * @deny (update) A non-admin user attempting to modify volunteer information.
     * @principle Secures a global collection using role-based access control.
     */
    match /volunteers/{volunteerId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Defines which users have admin privileges. This collection is read-only
     *              from the client to prevent privilege escalation.
     * @path /roles_admin/{userId}
     * @allow (none) All client-side access is denied.
     * @deny (create) Any user attempting to grant themselves admin rights.
     * @deny (get) Any user attempting to check if another user is an admin.
     * @principle Locks down a critical authorization collection to be managed only by
     *            trusted server-side processes or manually in the Firebase Console.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}