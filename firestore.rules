
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows any authenticated user to read and write to any document
    // in the database. It is a simple and effective rule for internal applications
    // where all signed-in users are trusted.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow access to the overtime collection
    match /overtime/{overtimeId} {
      allow read, write: if request.auth != null;
    }

    /*
    // Example for user-specific data (not currently used in this app)
    // This would restrict access to a user's own documents in a 'users' collection.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Example for admin-only access (not currently used in this app)
    // This would require a custom claim 'admin' to be set on the user's token.
    match /admin/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    */
  }
}
