rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are completely open and allow anyone to read, write,
    // and delete your data. This is for development convenience only.
    // SECURE YOUR RULES BEFORE GOING TO PRODUCTION.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
