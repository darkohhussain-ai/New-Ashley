
/**
 * @file firestore.rules
 * @description Firestore Security Rules for an internal HR expense management application.
 *
 * Core Philosophy:
 * This ruleset enforces an "authenticated-only" security model. It assumes that any user who has successfully signed in
 * is a trusted internal employee or administrator with full permissions to read and write all data in the database.
 * This is suitable for internal-facing applications where granular user roles are not required. Access is not restricted
 * based on who created the data, but rather on whether the user is part of the authenticated system.
 *
 * Data Structure:
 * The data is organized into several top-level collections:
 * - `/employees`: Stores profiles for all employees.
 * - `/expenses`: Stores all expense records.
 * - `/monthly_reports`: Aggregated reports.
 * - `/archived_expense_lists`: Historical expense data.
 *
 * Key Security Decisions:
 * - Global Authenticated Access: All read and write operations across all collections are permitted for any signed-in user.
 * - No Public Access: Unauthenticated users are denied all access to the database.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common authorization and validation logic.

    /**
     * Checks if the user is authenticated. This is the primary security check
     * for this internal application model.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that a document exists before allowing an update or delete.
     * This prevents erroneous writes to non-existent paths.
     */
    function documentExists() {
      return resource != null;
    }

    /**
     * Combines authentication and existence checks for state-changing operations.
     * Ensures that only signed-in users can modify or delete existing documents.
     */
    function isExistingDocAndSignedIn() {
      return isSignedIn() && documentExists();
    }

    /**
     * @description Rules for the 'employees' collection.
     * @path /employees/{employeeId}
     * @allow (create) A signed-in user creates a new employee profile.
     * @deny (create) An anonymous user attempts to create an employee profile.
     * @principle Grants full read and write access to any authenticated user, suitable for an internal company directory.
     */
    match /employees/{employeeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isExistingDocAndSignedIn();
      allow delete: if isExistingDocAndSignedIn();
    }

    /**
     * @description Rules for the 'expenses' collection.
     * @path /expenses/{expenseId}
     * @principle Grants full read and write access to any authenticated user for managing system-wide expenses.
     */
    match /expenses/{expenseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isExistingDocAndSignedIn();
      allow delete: if isExistingDocAndSignedIn();
    }

    /**
     * @description Rules for the 'monthly_reports' collection.
     * @path /monthly_reports/{reportId}
     * @allow (get) Any signed-in user can read a monthly report.
     * @deny (get) An anonymous user attempts to read a report.
     * @principle Grants full read and write access to any authenticated user for managing system-wide reports.
     */
    match /monthly_reports/{reportId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingDocAndSignedIn();
    }

    /**
     * @description Rules for the 'archived_expense_lists' collection.
     * @path /archived_expense_lists/{archiveId}
     * @allow (list) Any signed-in user can list all archived expense lists.
     * @deny (list) An anonymous user attempts to list archives.
     * @principle Grants full read and write access to any authenticated user for managing historical data archives.
     */
    match /archived_expense_lists/{archiveId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingDocAndSignedIn();
    }
  }
}
