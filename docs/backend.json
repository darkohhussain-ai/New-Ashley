
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee within the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Employee entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the employee."
        },
        "jobTitle": {
          "type": "string",
          "description": "The job title of the employee."
        },
        "employmentStartDate": {
          "type": "string",
          "description": "The date the employee started employment.",
          "format": "date-time"
        },
        "dateOfBirth": {
          "type": "string",
          "description": "The employee's date of birth.",
          "format": "date-time"
        },
        "email": {
          "type": "string",
          "description": "The employee's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The employee's phone number."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL of the employee's photo.",
          "format": "uri"
        },
        "notes": {
          "type": "string",
          "description": "Notes or additional information about the employee."
        }
      },
      "required": [
        "id",
        "name",
        "jobTitle",
        "employmentStartDate",
        "dateOfBirth",
        "email",
        "phone"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense incurred by an employee.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Expense entity."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee. (Relationship: Employee 1:N Expense)"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense."
        },
        "date": {
          "type": "string",
          "description": "The date the expense was incurred.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Notes or description of the expense."
        }
      },
      "required": [
        "id",
        "employeeId",
        "amount",
        "date"
      ]
    },
    "MonthlyReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MonthlyReport",
      "type": "object",
      "description": "Represents a monthly expense report for an employee.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MonthlyReport entity."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee. (Relationship: Employee 1:N MonthlyReport)"
        },
        "month": {
          "type": "string",
          "description": "The month the report is for (e.g., YYYY-MM).",
          "format": "date-time"
        },
        "totalExpenses": {
          "type": "number",
          "description": "The total expenses for the employee for the month."
        }
      },
      "required": [
        "id",
        "employeeId",
        "month",
        "totalExpenses"
      ]
    },
    "ArchivedExpenseList": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ArchivedExpenseList",
      "type": "object",
      "description": "Represents an archived expense list for a specific month.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ArchivedExpenseList entity."
        },
        "month": {
          "type": "string",
          "description": "The month the archived list is for (e.g., YYYY-MM).",
          "format": "date-time"
        },
        "expenseIds": {
          "type": "array",
          "description": "References to Expenses. (Relationship: ArchivedExpenseList 1:N Expense)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "month",
        "expenseIds"
      ]
    },
    "StorageLocation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StorageLocation",
      "type": "object",
      "description": "Represents a storage location.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the StorageLocation entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the location."
        },
        "warehouseType": {
          "type": "string",
          "description": "The type of warehouse (Ashley or Huana).",
          "enum": ["Ashley", "Huana"]
        }
      },
      "required": ["id", "name", "warehouseType"]
    },
    "ExcelFile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExcelFile",
      "type": "object",
      "description": "Represents a created or imported Excel file.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ExcelFile entity."
        },
        "storekeeperId": {
          "type": "string",
          "description": "ID of the storekeeper employee."
        },
        "storageName": {
          "type": "string",
          "description": "Name of the storage."
        },
        "categoryName": {
          "type": "string",
          "description": "Name of the category for the imported items."
        },
        "date": {
          "type": "string",
          "description": "Date of the file.",
          "format": "date-time"
        },
        "source": {
            "type": "string",
            "description": "Source of the imported file.",
            "enum": ["Showroom", "Ashley Store", "Huana Store"]
        },
        "type": {
          "type": "string",
          "description": "Type of file (new or imported).",
          "enum": ["new", "imported"]
        }
      },
      "required": ["id", "storekeeperId", "date", "type", "storageName", "categoryName", "source"]
    },
    "Item": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Item",
      "type": "object",
      "description": "Represents an item to be transferred. It is staged before being assigned to a transfer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Item entity."
        },
        "model": {
          "type": "string",
          "description": "The model of the item."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item."
        },
        "notes": {
          "type": "string",
          "description": "Notes about the item."
        },
        "destination": {
          "type": "string",
          "description": "The destination city for the item.",
          "enum": ["Erbil", "Baghdad", "Diwan", "Dohuk"]
        },
        "transferId": {
          "type": "string",
          "description": "The ID of the transfer slip this item belongs to. Null if not yet transferred."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the item was added to the transfer list."
        }
      },
      "required": ["id", "model", "quantity", "destination", "createdAt"]
    },
    "Transfer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transfer",
      "type": "object",
      "description": "Represents a cargo transfer slip, archiving a collection of transferred items.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Transfer entity."
        },
        "transferDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the transfer was created."
        },
        "cargoName": {
          "type": "string",
          "description": "A descriptive name for the cargo transfer."
        },
        "destinationCity": {
          "type": "string",
          "description": "The destination city for the transfer."
        },
        "driverName": {
          "type": "string",
          "description": "The name of the driver."
        },
        "warehouseManagerName": {
          "type": "string",
          "description": "The name of the warehouse manager."
        },
        "itemIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "An array of item IDs included in this transfer."
        }
      },
      "required": [
        "id",
        "transferDate",
        "cargoName",
        "destinationCity",
        "driverName",
        "warehouseManagerName",
        "itemIds"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": {
            "$ref": "#/backend/entities/Employee"
          },
          "description": "Stores employee profiles.",
          "params": [{ "name": "employeeId", "description": "Unique identifier for the employee." }]
        }
      },
      {
        "path": "/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Stores expenses for each employee.",
          "params": [{ "name": "expenseId", "description": "Unique identifier for the expense." }]
        }
      },
      {
        "path": "/storage_locations/{locationId}",
        "definition": {
          "entityName": "StorageLocation",
          "schema": {
            "$ref": "#/backend/entities/StorageLocation"
          },
          "description": "Stores storage locations.",
          "params": [{ "name": "locationId", "description": "Unique identifier for the storage location." }]
        }
      },
      {
        "path": "/excel_files/{fileId}",
        "definition": {
          "entityName": "ExcelFile",
          "schema": {
            "$ref": "#/backend/entities/ExcelFile"
          },
          "description": "Stores metadata for created or imported Excel files. This collection is now primarily for inventory management and is separate from the transfer process.",
          "params": [{ "name": "fileId", "description": "Unique identifier for the file." }]
        }
      },
      {
        "path": "/items/{itemId}",
        "definition": {
          "entityName": "Item",
          "schema": {
            "$ref": "#/backend/entities/Item"
          },
          "description": "Stores items staged for transfer. Once transferred, they are linked to a Transfer record via transferId.",
          "params": [{ "name": "itemId", "description": "Unique identifier for the item." }]
        }
      },
      {
        "path": "/transfers/{transferId}",
        "definition": {
          "entityName": "Transfer",
          "schema": {
            "$ref": "#/backend/entities/Transfer"
          },
          "description": "Stores archived transfer slips for cargo shipments.",
          "params": [{ "name": "transferId", "description": "Unique identifier for the transfer." }]
        }
      }
    ],
    "reasoning": "The data model is updated to support the new cargo transfer workflow. A top-level `/items` collection is introduced to stage items before they are assigned to a transfer. This decouples the transfer process from the main inventory stored in `/excel_files`. The `/transfers` collection will archive the created transfer slips, linking to the items that were part of that shipment. This structure provides a clear and scalable way to manage the entire lifecycle of a cargo transfer."
  }
}
