
{
  "entities": {
    "Volunteer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Volunteer",
      "type": "object",
      "description": "Represents a volunteer in the HR section.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the volunteer."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the volunteer."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the volunteer."
        },
        "email": {
          "type": "string",
          "description": "Email address of the volunteer.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the volunteer."
        },
        "address": {
          "type": "string",
          "description": "Address of the volunteer."
        },
        "availability": {
          "type": "string",
          "description": "Availability of the volunteer."
        },
        "notes": {
          "type": "string",
          "description": "Any notes about the volunteer."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email"
      ]
    },
    "Settings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Settings",
      "type": "object",
      "description": "Represents user-specific application settings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the settings."
        },
        "designColors": {
          "type": "string",
          "description": "Selected color scheme."
        },
        "applicationFonts": {
          "type": "string",
          "description": "Selected fonts for the application."
        },
        "darkModeEnabled": {
          "type": "boolean",
          "description": "Indicates if dark mode is enabled."
        }
      },
      "required": [
        "id"
      ]
    },
    "ApplicationLogo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ApplicationLogo",
      "type": "object",
      "description": "Represents the application logo.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the logo."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the application logo.",
          "format": "uri"
        },
        "uploadDate": {
          "type": "string",
          "description": "Date and time when the logo was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "logoUrl",
        "uploadDate"
      ]
    },
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Represents an administrator user with elevated privileges.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the admin user."
        },
        "username": {
          "type": "string",
          "description": "Username of the admin user."
        },
        "accessLevel": {
          "type": "string",
          "description": "Access level of the admin user."
        }
      },
      "required": [
        "id",
        "username",
        "accessLevel"
      ]
    },
    "MarketingEmployee": {
      "title": "MarketingEmployee",
      "description": "Represents a marketing employee being evaluated.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "EvaluationQuestion": {
      "title": "EvaluationQuestion",
      "description": "Represents a single question in the employee evaluation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "EvaluationResponse": {
      "title": "EvaluationResponse",
      "description": "Represents a submitted evaluation for a marketing employee.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "responses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "answer": { "type": "integer", "enum": [1, 2, 3] }
            }
          }
        },
        "totalScore": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/volunteers/{volunteerId}",
        "definition": {
          "entityName": "Volunteer",
          "schema": {
            "$ref": "#/backend/entities/Volunteer"
          },
          "description": "Stores volunteer information."
        }
      },
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "Settings",
          "schema": {
            "$ref": "#/backend/entities/Settings"
          },
          "description": "Stores application settings."
        }
      },
      {
        "path": "/application_logos/{logoId}",
        "definition": {
          "entityName": "ApplicationLogo",
          "schema": {
            "$ref": "#/backend/entities/ApplicationLogo"
          },
          "description": "Stores application logo information."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AdminUser",
          "schema": {
            "$ref": "#/backend/entities/AdminUser"
          },
          "description": "Stores admin user roles."
        }
      },
      {
        "path": "/overtime/{overtimeId}",
        "definition": {
          "entityName": "Overtime",
          "schema": {
            "$ref": "#/backend/entities/Overtime"
          },
          "description": "Stores overtime records."
        }
      },
       {
        "path": "/marketing-evaluations/{evaluationId}",
        "definition": {
          "entityName": "EvaluationResponse",
          "schema": { "$ref": "#/backend/entities/EvaluationResponse" },
          "description": "Stores evaluation responses for marketing employees."
        }
      }
    ]
  }
}
